# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback)
OPENAI_API_KEY=sk-...

# Reddit discovery uses the anonymous public JSON endpoint - no API key needed.
# Just give yourself a descriptive User-Agent so Reddit doesn't 429 you.
REDDIT_USER_AGENT=synthaudience:v0.1.0 (by /u/your-handle)

# Models
BROWSE_MODEL=claude-haiku-4-5-20251001
EVAL_MODEL=claude-sonnet-4-6

# Discovery schedule (minutes between browse cycles).
# 60 = once per hour. Anonymous Reddit limit is ~10 req/min so even 15
# is well under for a 12-agent population. Don't go below 5.
DISCOVERY_INTERVAL_MINUTES=60

# Data paths
DATABASE_URL=sqlite:///data/synthaudience.db
CHROMA_PERSIST_DIR=data/chroma
