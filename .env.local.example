# Copy to .env.local and fill in. Never commit .env.local — it's gitignored.

# --- AI Gateway --------------------------------------------------------------
# Create a key: https://vercel.com/ai-gateway
# Or run `npx vercel link && npx vercel env pull .env.local` to use OIDC.
AI_GATEWAY_API_KEY=

# Default model for /api/chat. Browse the list:
#   curl -s https://ai-gateway.vercel.sh/v1/models | jq -r '.data[].id' | sort
# Good defaults:
#   openai/gpt-5.4-mini             (cheap + fast)
#   anthropic/claude-sonnet-4.6     (best general)
#   google/gemini-3.1-pro-preview   (long context)
AI_MODEL=openai/gpt-5.4-mini

# Optional: shows the model name in the chat header (client-side, public).
NEXT_PUBLIC_AI_MODEL=openai/gpt-5.4-mini

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (used by API routes + worker). Project Settings → API → service_role.
SUPABASE_SERVICE_KEY=

# --- Anthropic --------------------------------------------------------------
# console.anthropic.com → API keys. Powers /api/draft, /api/reply, /api/classify.
ANTHROPIC_API_KEY=

# --- Twilio (optional — SMS approval flow) ----------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
USER_PHONE_NUMBER=
