# Copy to agent/.env and fill in. Never commit agent/.env (gitignored).
# These same values must be set as Ara secrets when deploying:
#   ara secrets set X_API_KEY=... (etc.)

# --- X / Twitter -------------------------------------------------------------
# Get at developer.twitter.com → your app → Keys and tokens.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# --- Supabase ----------------------------------------------------------------
# Project Settings → API. Use the service-role key here so the agent has full DB access.
# (The Next.js dashboard uses the anon key, set in .env.local.)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- SMS approval (Ara linq_send_message connector) --------------------------
# E.164 format, e.g. +14155551234
USER_PHONE_NUMBER=
